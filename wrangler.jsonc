{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "lossless-url-compressor",
  "main": "src/worker.ts",
  "compatibility_date": "2026-05-28",
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist"
  },
  "routes": [
    {
      "zone_name": "piss.zip",
      "custom_domain": true,
      "pattern": "piss.zip"
    }
  ]
}
